{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Shared team config: pre-approved safe commands (fewer permission prompts) and a PostToolUse hook that auto-formats edited Dart files. Personal, machine-specific overrides go in .claude/settings.local.json (gitignored). See docs/agentic-workflow.md.",
  "permissions": {
    "allow": [
      "Bash(dart format:*)",
      "Bash(dart analyze:*)",
      "Bash(dart test:*)",
      "Bash(dart pub get:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter pub get:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh .claude/hooks/format-dart.sh"
          }
        ]
      }
    ]
  }
}
